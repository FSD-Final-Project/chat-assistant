ROCKET_CREDENTIALS_ENCRYPTION_KEY=your-encryption-key
ACCESS_TOKEN_SECRET=your-access-token-secret
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_HASH_SECRET=your-refresh-token-hash-secret
