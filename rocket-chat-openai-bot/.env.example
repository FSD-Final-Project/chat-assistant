RC_URL=https://open.rocket.chat
MAIN_SERVER_URL=http://localhost:3001
INTERNAL_API_KEY=replace-this-with-the-same-internal-key-used-by-server
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SYSTEM_PROMPT=You are a helpful Rocket.Chat assistant. be careful with your answers based on the user name of the user you are talking to.
POLL_INTERVAL_MS=3000
RC_REQUEST_INTERVAL_MS=400
RC_RETRY_BACKOFF_MS=5000
MAX_CONTEXT_MESSAGES=12
BOT_TRIGGER_PREFIX=
MIRROR_USER_STYLE=true
MIRROR_STYLE_SAMPLE_SIZE=6
SPEAK_AS_USER=true
